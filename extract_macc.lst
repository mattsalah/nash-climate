   1  * ------------------------------------------------
   2  * Standalone MACC parameter extractor for RICE50+
   3  * ------------------------------------------------
   4   
  12   
  13  * --- SETS ---
  14  SET t;
  15  ALIAS(t, tp1);
  16  SET pre(t,tp1);
  17  SET n /
  18      arg, aus, aut, bel, bgr, blt, bra, can, chl, chn, cor, cro,
  19      dnk, egy, esp, fin, fra, gbr, golf57, grc, hun, idn, irl, ita,
  20      jpn, meme, mex, mys, nde, nld, noan, noap, nor, oeu, osea, pol,
  21      prt, rcam, rcz, rfa, ris, rjan57, rom, rsaf, rsam, rsas, rsl,
  22      rus, sau, slo, sui, swe, tha, tur, ukr, usa, vnm, zaf /;
  23   
  24  SET sector 'EnerData sectors' /
  25      "Electricity"
  26      "Other_energy_transformation"
  27      "Total_buildings_agriculture"
  28      "Total_industry_processes"
  29      "Total_industry_fuelcombustion"
  30      "Total_CO2"
  31      "Total_transport" /;
  32  SET quant  'AR6 quantiles' / "prob25","prob33","prob50","prob66","prob75" /;
  33  SET coef   'Polynomial coefficients' / c0*c4 /;
  34  SET ghg    'Greenhouse gases' / co2, ch4, n2o /;
  35  SET coefact(coef,*) / c1.co2, c4.co2 /;
  36   
  37  * --- TIME PARAMETERS (must be declared before include) ---
  38  PARAMETER tperiod(t);
  39  PARAMETER year(t);
  40  PARAMETER tlen(t);
  41  PARAMETER begyear(t);
  42  PARAMETER preds(t,t);
