2049   
2050  * --- SCALAR PARAMETERS ---
2051  PARAMETERS
2052      expcost2  / 2.8 /
2053      pback     / 550    /
2054      gback     / 0.025    /
2055  ;
2056   
2057  PARAMETER coefn(coef) / c0 0, c1 1, c2 2, c3 3, c4 4 /;
2058   
2059   
2060  **********************************************
2061  * ----------- MACC CALCULATIONS ---------------
2062  **********************************************
2063   
2064  * --- LOAD RAW DATA ---
2065  PARAMETER macc_ed_coef(sector,*,t,n);
GDXIN   /Users/matthewsalah/Documents/Columbia/2026S/Collective Action/Final Paper/code/RICE50xmodel/data_ed58/data_mod_macc.gdx
--- LOAD  macc_ed_coef = 1:macc_ed_coef
2069   
2070  PARAMETER mx_correction_factor(sector,quant,t,n);
GDXIN   /Users/matthewsalah/Documents/Columbia/2026S/Collective Action/Final Paper/code/RICE50xmodel/data_ed58/data_mod_macc.gdx
--- LOAD  mx_correction_factor = 3:mx_correction_factor
2074   
2075  * --- COMPUTED PARAMETERS ---
2076  PARAMETERS
2077      pbacktime(t)
2078      macc_coef(t,n,*,coef)
2079      mx(t,n,ghg)
2080      MXpback(t,n,ghg)
2081      MXstart(t,n,ghg)
2082      MXdiff(t,n,ghg)
2083      alpha(t)
2084  ;
2085   
2086  * Map raw enerdata coefficients
2087  macc_coef(t,n,'co2','c1') = macc_ed_coef('Total_CO2','a',t,n);
2088  macc_coef(t,n,'co2','c4') = macc_ed_coef('Total_CO2','d',t,n);
2089  macc_coef(t,n,'co2',coef)$(macc_coef(t,n,'co2',coef) < 0) = 0;
2090   
2091  * Backstop price path
2092  pbacktime(t) = pback * (1-gback)**(tperiod(t)-1);
2093   
2094  * Logistic transition to backstop
2095  SCALAR x0;
2096  x0 = 7 + ((28-7)/2);
2097  alpha(t) = 1 / (1 + exp(-0.25 * (tperiod(t) - x0)));
2098   
2099  * MX starting value (SSP2 default = prob50)
2100  MXstart(t,n,'co2') = mx_correction_factor('Total_CO2','prob50',t,n);
2101   
2102  * Backstop multiplier
2103  MXpback(t,n,'co2')$(macc_ed_coef('Total_CO2','a',t,n) + macc_ed_coef('Total_CO2','d',t,n) > 0)
2104      = pbacktime(t) / (macc_ed_coef('Total_CO2','a',t,n) + macc_ed_coef('Total_CO2','d',t,n));
2105   
2106  MXdiff(t,n,'co2') = max(MXstart(t,n,'co2') - MXpback(t,n,'co2'), 0);
2107   
2108  * Final mx
2109  mx(t,n,'co2') = MXstart(t,n,'co2') - alpha(t) * MXdiff(t,n,'co2');
2110   
2111  * Apply mx to get final scaled coefficients
2112  macc_coef(t,n,'co2','c1') = mx(t,n,'co2') * macc_ed_coef('Total_CO2','a',t,n);
2113  macc_coef(t,n,'co2','c4') = mx(t,n,'co2') * macc_ed_coef('Total_CO2','d',t,n);
2114   
2115   
2116  * --- OUTPUT ---
2117  execute_unload 'output/data/macc_extract.gdx',
2118      macc_ed_coef,
2119      macc_coef,
2120      mx_correction_factor,
2121      mx,
2122      alpha,
2123      pbacktime,
2124      tperiod,
2125      year;
2126   
2127  SET t_early(t) / 1, 2, 3 /;
2128   
2129  FILE fout / 'output/data/macc_ed_early.csv' /;
2130  PUT fout;
2131  PUT '"sector","Dim2","t","n","Val"' /;
2132   
2133  LOOP((t_early(t), n),
2134      PUT '"Total_CO2","a","' t.tl '","' n.tl '",' macc_ed_coef('Total_CO2','a',t,n):0:12 /;
2135      PUT '"Total_CO2","d","' t.tl '","' n.tl '",' macc_ed_coef('Total_CO2','d',t,n):0:12 /;
2136  );
2137   
2138  PUTCLOSE fout;
2139   
2140   
2141   
2142  **********************************************
2143  * ----------- BAU CALCULATIONS ---------------
2144  **********************************************
2145   
2146  *** * --- LOAD BASELINE DATA ---
2147  *** SET ssp / SSP1, SSP2, SSP3, SSP4, SSP5 /;
2148  *** SET ghg2 / co2, ch4, n2o /;
2149  ***
2150  *** PARAMETER ssp_ci(ssp,t,n,ghg2);
2151  *** PARAMETER ssp_ykali(ssp,t,n);
2152  *** PARAMETER convq_ghg(ghg2) / co2 1, ch4 1e-3, n2o 1e-3 /;
2153  ***
2154  *** $gdxin '%datapath%data_baseline'
2155  *** $load ssp_ci
2156  *** $load ssp_ykali
2157  *** $gdxin
2158  ***
2159  *** * --- COMPUTE EMI_BAU FOR SSP2, CO2, t=1,2,3 ---
2160  *** PARAMETER emi_bau_early(t,n);
2161  ***
2162  *** emi_bau_early(t_early,n) = convq_ghg('co2')
2163  ***                           * ssp_ci('SSP2', t_early, n, 'co2')
2164  ***                           * ssp_ykali('SSP2', t_early, n);
2165  ***
2166  *** * --- WRITE TO CSV ---
2167  *** FILE fout2 / 'output/data/emi_bau_early.csv' /;
2168  *** PUT fout2;
2169  *** PUT '"t","n","emi_bau_GtCO2yr"' /;
2170  ***
2171  *** LOOP((t_early(t), n),
2172  ***     PUT '"' t.tl '","' n.tl '",' emi_bau_early(t,n):0:12 /;
2173  *** );
2174  ***
2175  *** PUTCLOSE fout2;
